    const params = new URLSearchParams(window.location.search);
    const slug = params.get("prospect") || "";
    const prospect = prospects[slug];
    const demoLink = document.getElementById("demoLink");

    document.getElementById("prospectSlug").value = slug;

    if (prospect) {
      document.title = `JPAX Media | ${prospect.name} Local Visibility Sprint`;
      document.getElementById("heroEyebrow").textContent = `${prospect.category} note for ${prospect.city}`;
      document.getElementById("heroTitle").textContent = `Hey ${prospect.name}, I made this for you.`;
      document.getElementById("heroLead").textContent = `I’m Julian with JPAX Media. I was looking at local service businesses in the Upstate and put together a site preview for ${prospect.name}, plus a simple 90-day plan to make the online presence easier to trust and use.`;
      document.getElementById("introCopy").textContent = `I already selected ${prospect.name} from the QR code. If you want the preview link, send the form and I will follow up personally.`;
      document.getElementById("businessField").value = prospect.name;
      document.getElementById("demoUrl").value = prospect.demo;
      document.getElementById("messageField").value = `I scanned the JPAX postcard for ${prospect.name}. Please send me the site preview and your thoughts on what you would clean up first.`;
      document.getElementById("demoCopy").textContent = `The preview link for ${prospect.name} is ready. Send the form and I will send it over personally.`;
      demoLink.href = "#respond";
    } else {
      demoLink.style.display = "none";
    }
  </script>
